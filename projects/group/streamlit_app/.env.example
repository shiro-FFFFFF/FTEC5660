# Copy to streamlit_app/.env and adjust only what you need.

# Optional scam-signal MCP streamable HTTP endpoint.
# Default: empty (disabled unless GUARDIAN_MCP_ENABLED is truthy or endpoint is set)
GUARDIAN_MCP_ENDPOINT=http://127.0.0.1:8765/mcp

# Optional BANK TRANSFER REVIEW MCP streamable HTTP endpoint.
# Default: empty (disabled)
GUARDIAN_BANK_REVIEW_MCP_ENDPOINT=http://127.0.0.1:8766/mcp

# Optional toggle for the scam-signal MCP endpoint.
# Default: empty (auto-enable only when GUARDIAN_MCP_ENDPOINT is set)
GUARDIAN_MCP_ENABLED=

# When true, MCP failures do not fall back to local signals.
# Default: false
GUARDIAN_MCP_STRICT=false

# Timeout in seconds for the scam-signal MCP endpoint.
# Default: 3.0
GUARDIAN_MCP_TIMEOUT_S=3.0

# Optional scenario id to auto-play on first load.
# Default: empty
GUARDIAN_AUTOPLAY=

# Optional cap on idle gaps between scenario events, in seconds.
# Default: empty (disabled; use original scenario timing)
GUARDIAN_SCENARIO_MAX_IDLE_S=

# Enable LangChain / ReAct tool-use risk scoring.
# Default: empty / false
GUARDIAN_REACT=1

# Ollama connection settings.
# Default: http://localhost:11434
OLLAMA_ENDPOINT=http://localhost:11434

# Default Ollama model.
# Default: llama3.2:3b
OLLAMA_MODEL=llama3.2:3b

# Per-inference timeout in seconds.
# Default: 120
OLLAMA_TIMEOUT=120

# Warmup timeout in seconds.
# Default: 60
OLLAMA_WARMUP_TIMEOUT=60

# Ollama model keep-alive value.
# Default: 15m
OLLAMA_KEEP_ALIVE=15m

# API key passed to the OpenAI-compatible Ollama endpoint.
# Default: ollama
OLLAMA_API_KEY=ollama
